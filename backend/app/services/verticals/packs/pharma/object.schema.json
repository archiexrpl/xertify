{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pharma Object Snapshot v1",
  "type": "object",
  "required": ["object_id", "vertical_id", "kind", "facts"],
  "properties": {
    "object_id": { "type": "string", "minLength": 1 },
    "vertical_id": { "type": "string", "const": "pharma" },
    "kind": { "type": "string", "enum": ["batch", "shipment", "package"] },
    "facts": {
      "type": "object",
      "required": ["batch_id", "product_name", "manufacturer"],
      "properties": {
        "batch_id": { "type": "string" },
        "product_name": { "type": "string" },
        "manufacturer": { "type": "string" },

        "mfg_date": { "type": ["string", "null"], "description": "ISO-8601" },
        "exp_date": { "type": ["string", "null"], "description": "ISO-8601" },

        "cold_chain_required": { "type": "boolean", "default": false },
        "temp_min": { "type": ["number", "null"] },
        "temp_max": { "type": ["number", "null"] },

        "recall_status": { "type": ["string", "null"], "enum": ["", "none", "recalled", null] },
        "recall_id": { "type": ["string", "null"] },

        "custodian": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
